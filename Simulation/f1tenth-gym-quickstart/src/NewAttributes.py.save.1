import numpy as np
#from Sim_Nav import Navigation
import joblib

class NewStuff:

    BUBBLE_RADIUS = 160
    PREPROCESS_CONV_SIZE = 3
    BEST_POINT_CONV_SIZE = 80
    MAX_LIDAR_DIST = 3000000
    STRAIGHTS_SPEED = 3.0
    CORNERS_SPEED = 2.0
    STRAIGHTS_STEERING_ANGLE = np.pi / 18
    
    def __init__(self):
        self.reversing = False
        self.radians_per_elem = None
        self.prev_speed = 0.0
        self.prev_steering = 0.0

        # Load the trained ML model
        self.model = joblib.load('my_rf_model.pkl')
    
    def preprocess_lidar(self, ranges):
        
        self.radians_per_elem = (2*np.pi) / len(ranges)
        proc_ranges = np.array(ranges[135:-135])

        proc_ranges = np.convolve(proc_ranges, np.ones(self.PREPROCESS_CONV_SIZE), 'same') / self.PREPROCESS_CONV_SIZE
        proc_ranges = np.clip(proc_ranges, 0, self.MAX_LIDAR_DIST)
        return proc_ranges

    def find_max_gap(self, free_space_ranges):
        
        masked = np.ma.masked_where(free_space_ranges==0, free_space_ranges)

        slices = np.ma.notmasked_contiguous(masked)
        max_len = slices[0].stop - slices[0].start
        chosen_slice = slices[0]
        
        for sl in slices[1:]:
            sl_len = sl.stop - sl.start
            if sl_len > max_len:
                max_len = sl_len
                chosen_slice = sl
        return chosen_slice.start, chosen_slice.stop
    
    def find_best_point(self, start_i, end_i, ranges):
        """Start_i & end_i are start and end indices of max-gap range, respectively
        Return index of best point in ranges
	    Naive: Choose the furthest point within ranges and go there"""
        
        averaged_max_gap = np.convolve(ranges[start_i:end_i], np.ones(self.BEST_POINT_CONV_SIZE), 'same') / self.BEST_POINT_CONV_SIZE
        return averaged_max_gap.argmax() + start_i

    def get_angle(self, range_index, range_len):
        """ Get the angle of a particular element in the LiDAR data and transform it into an appropriate steering angle"""
        lidar_angle = (range_index - (range_len/2)) * self.radians_per_elem
        # steering_angle = lidar_angle / 2
        steering_angle = lidar_angle
        return steering_angle

    def process_lidar(self, scan, x, y):
        proc_ranges = self.preprocess_lidar(scan)
        closest = proc_ranges.argmin()
       
        min_index = max(0, closest - self.BUBBLE_RADIUS)
        max_index = min(len(proc_ranges) - 1, closest + self.BUBBLE_RADIUS)
        proc_ranges[min_index:max_index] = 0

        gap_start, gap_end = self.find_max_gap(proc_ranges)
        best = self.find_best_point(gap_start, gap_end, proc_ranges)
        steering_angle = self.get_angle(best, len(proc_ranges))

        steer_ratio = abs(steering_angle) / (np.pi / 2)
        speed = self.STRAIGHTS_SPEED - (self.STRAIGHTS_SPEED - self.CORNERS_SPEED) * steer_ratio

        center_index = len(scan) // 2
        min_front_dist = scan[center_index]
        effective_speed = speed * np.cos(steering_angle)

        if self.reversing:
            # print("Reversing...")
            if min_front_dist > 1.0:
                self.reversing = False
                # print("Safe — exiting reverse mode.")
            else:
                return -1.0, 0.0

        elif abs(steering_angle) < (np.pi / 4) and speed > 0:
            if effective_speed > 0:
                steps_to_hit = min_front_dist / effective_speed
                if steps_to_hit < 0.5:
                    self.reversing = True
                    # print("Too close — entering reverse mode.")
                    return -1.0, 0.0
                # else:
                    # print(f"{steps_to_hit:.1f} steps to obstacle.")
            # else:
                # print("Effective speed zero — can't estimate steps.")
        # else:
        #     print("Steering angle too large or speed too low to check frontal collision.")

        # print(f"Speed: {speed:.2f} | Steering: {steering_angle:.2f}")
        return speed, steering_angle, min_front_dist
